{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fourier SVG Visualizer",
  "version": "1.0.0",
  "identifier": "com.fourier.visualizer",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Fourier SVG Visualizer",
        "width": 1050,
        "height": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "fs": {
      "scope": ["**"]
    },
    "dialog": {
      "scope": ["**"]
    }
  }
}
